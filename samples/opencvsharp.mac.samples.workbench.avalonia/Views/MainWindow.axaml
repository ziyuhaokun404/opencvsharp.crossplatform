<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenCvSharp.Mac.Samples.Workbench.Avalonia.ViewModels"
        xmlns:models="using:OpenCvSharp.Mac.Samples.Workbench.Avalonia.ViewModels.Models"
        x:Class="OpenCvSharp.Mac.Samples.Workbench.Avalonia.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1480"
        Height="940"
        MinWidth="1200"
        MinHeight="780"
        Title="OpenCvSharp 图像处理工作台"
        Background="{DynamicResource AppSurfaceBrush}">
  <Window.Styles>
    <Style Selector="TextBlock.h1">
      <Setter Property="FontSize" Value="18" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}" />
    </Style>
    <Style Selector="TextBlock.sectionTitle">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{DynamicResource TextLabelBrush}" />
    </Style>
    <Style Selector="TextBlock.caption">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="Foreground" Value="{DynamicResource TextMutedBrush}" />
    </Style>
    <Style Selector="Button">
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="12,5" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}" />
    </Style>
    <Style Selector="Button.primary">
      <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>
    <Style Selector="Button.toolbarIcon">
      <Setter Property="Width" Value="34" />
      <Setter Property="MinWidth" Value="34" />
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.toolbarPrimary">
      <Setter Property="Width" Value="38" />
      <Setter Property="MinWidth" Value="38" />
      <Setter Property="Height" Value="34" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
      <Setter Property="BorderThickness" Value="1" />
    </Style>
    <Style Selector="Button.modeSegment">
      <Setter Property="MinWidth" Value="58" />
      <Setter Property="MinHeight" Value="26" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="Button.modeSegment.active">
      <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
    </Style>
    <Style Selector="Button.switchButton">
      <Setter Property="Width" Value="44" />
      <Setter Property="MinWidth" Value="44" />
      <Setter Property="Height" Value="24" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>
    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorderBrush}" />
      <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}" />
    </Style>
    <Style Selector="TextBox.paramInput">
      <Setter Property="Width" Value="72" />
      <Setter Property="MinWidth" Value="72" />
      <Setter Property="MinHeight" Value="28" />
      <Setter Property="Padding" Value="8,2" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="HorizontalContentAlignment" Value="Right" />
    </Style>
    <Style Selector="Slider.paramSlider">
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Margin" Value="0,2,0,0" />
    </Style>
    <Style Selector="ListBox">
      <Setter Property="Background" Value="{DynamicResource ControlSurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardBorderBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}" />
    </Style>
    <Style Selector="ListBoxItem">
      <Setter Property="Padding" Value="4" />
    </Style>
    <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource BadgeSurfaceBrush}" />
    </Style>
    <Style Selector="ListBox.flow">
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
    </Style>
    <Style Selector="ListBox.flow ListBoxItem">
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.flow ListBoxItem /template/ ContentPresenter">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="ListBox.flow ListBoxItem:selected /template/ ContentPresenter">
      <Setter Property="Background" Value="{DynamicResource BadgeSurfaceBrush}" />
    </Style>
    <Style Selector="TabControl">
      <Setter Property="Background" Value="Transparent" />
    </Style>
    <Style Selector="TabItem">
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
    </Style>
    <Style Selector="TabItem:selected">
      <Setter Property="Foreground" Value="{DynamicResource TextBodyBrush}" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="58,*,Auto,24" Background="{DynamicResource AppSurfaceBrush}">
    <Border Grid.Row="0" Background="{DynamicResource ChromeSurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,Auto,Auto,*" Margin="14,10" ColumnSpacing="14">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <Button Classes="toolbarPrimary" ToolTip.Tip="导入图像" Command="{Binding ImportImageCommand}">
            <Viewbox Width="19" Height="19">
              <Canvas Width="24" Height="24">
                <Path Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M21,15 L21,19 A2,2 0,0 1,19 21 L5,21 A2,2 0,0 1,3 19 L3,15" />
                <Path Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M17,8 L12,3 L7,8" />
                <Path Stroke="{DynamicResource PrimaryTextBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M12,3 L12,15" />
              </Canvas>
            </Viewbox>
          </Button>
          <Button Classes="toolbarIcon" ToolTip.Tip="导出结果" Command="{Binding ExportResultCommand}">
            <Viewbox Width="19" Height="19">
              <Canvas Width="24" Height="24">
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M21,15 L21,19 A2,2 0,0 1,19 21 L5,21 A2,2 0,0 1,3 19 L3,15" />
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M7,10 L12,15 L17,10" />
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M12,15 L12,3" />
              </Canvas>
            </Viewbox>
          </Button>
          <Button Classes="toolbarIcon" ToolTip.Tip="创建示例" Command="{Binding NewSampleCommand}">
            <TextBlock Text="+" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
          <Button Classes="toolbarIcon" ToolTip.Tip="保存结果到素材库" Command="{Binding DuplicateResultCommand}">
            <Viewbox Width="18" Height="18">
              <Canvas Width="24" Height="24">
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" Data="M8,8 L19,8 L19,19 L8,19 Z" />
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" Data="M5,16 L5,5 L16,5" />
              </Canvas>
            </Viewbox>
          </Button>
        </StackPanel>

        <Border Grid.Column="1" Width="1" Margin="0,2" Background="{DynamicResource DividerBrush}" />

        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
          <Button Classes="toolbarPrimary" ToolTip.Tip="运行处理流程" Command="{Binding RunPipelineCommand}">
            <Viewbox Width="18" Height="18">
              <Canvas Width="24" Height="24">
                <Path Fill="{DynamicResource PrimaryTextBrush}" Data="M8,5 L19,12 L8,19 Z" />
              </Canvas>
            </Viewbox>
          </Button>
          <Button Classes="toolbarIcon" ToolTip.Tip="撤销" Command="{Binding UndoCommand}">
            <Viewbox Width="18" Height="18">
              <Canvas Width="24" Height="24">
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M9,14 L4,9 L9,4" />
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M4,9 L14.5,9 A5.5,5.5 0,0 1,20 14.5 A5.5,5.5 0,0 1,14.5 20 L11,20" />
              </Canvas>
            </Viewbox>
          </Button>
          <Button Classes="toolbarIcon" ToolTip.Tip="重做" Command="{Binding RedoCommand}">
            <Viewbox Width="18" Height="18">
              <Canvas Width="24" Height="24">
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M15,14 L20,9 L15,4" />
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M20,9 L9.5,9 A5.5,5.5 0,0 0,4 14.5 A5.5,5.5 0,0 0,9.5 20 L13,20" />
              </Canvas>
            </Viewbox>
          </Button>
        </StackPanel>

        <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
          <Border Background="{DynamicResource ControlSurfaceBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="2">
            <StackPanel Orientation="Horizontal" Spacing="1">
              <Button Classes="modeSegment" Classes.active="{Binding IsSideBySideMode}" Content="对比" Command="{Binding SetCanvasModeCommand}" CommandParameter="SideBySide" />
              <Button Classes="modeSegment" Classes.active="{Binding IsResultOnlyMode}" Content="结果" Command="{Binding SetCanvasModeCommand}" CommandParameter="ResultOnly" />
              <Button Classes="modeSegment" Classes.active="{Binding IsSliderCompareMode}" Content="滑动对比" Command="{Binding SetCanvasModeCommand}" CommandParameter="Slider" />
            </StackPanel>
          </Border>
          <Border Width="1" Margin="4,2" Background="{DynamicResource DividerBrush}" />
          <Button Classes="toolbarIcon" ToolTip.Tip="适应视图" Command="{Binding FitCommand}">
            <Viewbox Width="18" Height="18">
              <Canvas Width="24" Height="24">
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M8,3 L5,3 A2,2 0,0 0,3 5 L3,8" />
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M16,3 L19,3 A2,2 0,0 1,21 5 L21,8" />
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M21,16 L21,19 A2,2 0,0 1,19 21 L16,21" />
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M8,21 L5,21 A2,2 0,0 1,3 19 L3,16" />
              </Canvas>
            </Viewbox>
          </Button>
          <Button Classes="toolbarIcon" ToolTip.Tip="原始尺寸" Command="{Binding ActualSizeCommand}">
            <Viewbox Width="18" Height="18">
              <Canvas Width="24" Height="24">
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M5,5 L11,5 L11,11 L5,11 Z" />
                <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M13,13 L19,13 L19,19 L13,19 Z" />
              </Canvas>
            </Viewbox>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Grid Grid.Row="1" ColumnDefinitions="204,*,352">
      <Border Grid.Column="0" Background="{DynamicResource PanelSurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,0,1,0">
        <Grid RowDefinitions="Auto,*" Margin="14" RowSpacing="12">
          <StackPanel Spacing="3">
            <TextBlock Text="素材" Classes="h1" />
          </StackPanel>

          <Grid Grid.Row="1" RowDefinitions="Auto,*">
            <Grid>
              <TextBlock Text="图像素材" Classes="sectionTitle" />
            </Grid>
            <ListBox Grid.Row="1"
                     Margin="0,8,0,0"
                     ItemsSource="{Binding Assets}"
                     SelectedItem="{Binding SelectedAsset, Mode=TwoWay}">
              <ListBox.ItemTemplate>
                <DataTemplate x:DataType="models:ImageAssetViewModel">
                  <Grid ColumnDefinitions="3,*" Margin="0,1">
                    <Border Width="3" CornerRadius="2" Background="{DynamicResource PrimaryBrush}" />
                    <StackPanel Grid.Column="1" Margin="8,6" Spacing="2">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" TextWrapping="Wrap" />
                      <TextBlock Text="{Binding SizeText}" Classes="caption" />
                      <TextBlock Text="{Binding Note}" Classes="caption" />
                    </StackPanel>
                  </Grid>
                </DataTemplate>
              </ListBox.ItemTemplate>
            </ListBox>
          </Grid>
        </Grid>
      </Border>

      <Grid Grid.Column="1" Background="{DynamicResource CanvasBackdropBrush}">
        <Grid>
          <Grid IsVisible="{Binding IsSideBySideMode}" ColumnDefinitions="*,*">
            <Border Background="{DynamicResource PreviewPanelBrush}" BorderBrush="{DynamicResource PreviewBorderBrush}" BorderThickness="1" ClipToBounds="True">
              <Grid RowDefinitions="36,*">
                <Border Background="{DynamicResource PreviewHeaderBrush}" BorderBrush="{DynamicResource PreviewBorderBrush}" BorderThickness="0,0,0,1">
                  <Grid Margin="14,0">
                    <TextBlock Text="输入" VerticalAlignment="Center" Foreground="{DynamicResource PreviewTextBrush}" FontWeight="SemiBold" />
                  </Grid>
                </Border>
                <Grid Grid.Row="1" Background="{DynamicResource ImageWellBrush}">
                  <Image Source="{Binding InputImageSource}" Stretch="{Binding ImageStretch}" IsVisible="{Binding InputImageVisible}" />
                  <TextBlock Text="{Binding InputPlaceholderText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="18" IsVisible="{Binding InputPlaceholderVisible}" />
                </Grid>
              </Grid>
            </Border>

            <Border Grid.Column="1" Background="{DynamicResource PreviewPanelBrush}" BorderBrush="{DynamicResource PreviewBorderBrush}" BorderThickness="1" ClipToBounds="True">
              <Grid RowDefinitions="36,*">
                <Border Background="{DynamicResource PreviewHeaderBrush}" BorderBrush="{DynamicResource PreviewBorderBrush}" BorderThickness="0,0,0,1">
                  <Grid Margin="14,0">
                    <TextBlock Text="输出" VerticalAlignment="Center" Foreground="{DynamicResource PreviewTextBrush}" FontWeight="SemiBold" />
                  </Grid>
                </Border>
                <Grid Grid.Row="1" Background="{DynamicResource ImageWellBrush}">
                  <Image Source="{Binding OutputImageSource}" Stretch="{Binding ImageStretch}" IsVisible="{Binding OutputImageVisible}" />
                  <TextBlock Text="{Binding OutputPlaceholderText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="18" IsVisible="{Binding OutputPlaceholderVisible}" />
                </Grid>
              </Grid>
            </Border>
          </Grid>

          <Border IsVisible="{Binding IsResultOnlyMode}" Background="{DynamicResource PreviewPanelBrush}" BorderBrush="{DynamicResource PreviewBorderBrush}" BorderThickness="1" ClipToBounds="True">
            <Grid RowDefinitions="36,*">
              <Border Background="{DynamicResource PreviewHeaderBrush}" BorderBrush="{DynamicResource PreviewBorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="14,0">
                  <TextBlock Text="输出" VerticalAlignment="Center" Foreground="{DynamicResource PreviewTextBrush}" FontWeight="SemiBold" />
                </Grid>
              </Border>
              <Grid Grid.Row="1" Background="{DynamicResource ImageWellBrush}">
                <Image Source="{Binding OutputImageSource}" Stretch="{Binding ImageStretch}" IsVisible="{Binding OutputImageVisible}" />
                <TextBlock Text="{Binding OutputPlaceholderText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="18" IsVisible="{Binding OutputPlaceholderVisible}" />
              </Grid>
            </Grid>
          </Border>

          <Border IsVisible="{Binding IsSliderCompareMode}" Background="{DynamicResource PreviewPanelBrush}" BorderBrush="{DynamicResource PreviewBorderBrush}" BorderThickness="1" ClipToBounds="True">
            <Grid RowDefinitions="36,*">
              <Border Background="{DynamicResource PreviewHeaderBrush}" BorderBrush="{DynamicResource PreviewBorderBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="14,0">
                  <TextBlock Text="滑动对比" VerticalAlignment="Center" Foreground="{DynamicResource PreviewTextBrush}" FontWeight="SemiBold" />
                </Grid>
              </Border>
              <Grid Grid.Row="1" Name="SliderCompareWell" Background="{DynamicResource ImageWellBrush}" ClipToBounds="True">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="{Binding CompareInputWidth}" />
                  <ColumnDefinition Width="{Binding CompareOutputWidth}" />
                </Grid.ColumnDefinitions>
                <Image Grid.ColumnSpan="2"
                       Width="{Binding Bounds.Width, ElementName=SliderCompareWell}"
                       Height="{Binding Bounds.Height, ElementName=SliderCompareWell}"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Center"
                       Source="{Binding OutputImageSource}"
                       Stretch="{Binding ImageStretch}"
                       IsVisible="{Binding OutputImageVisible}" />
                <Border ClipToBounds="True">
                  <Image Width="{Binding Bounds.Width, ElementName=SliderCompareWell}"
                         Height="{Binding Bounds.Height, ElementName=SliderCompareWell}"
                         HorizontalAlignment="Left"
                         VerticalAlignment="Center"
                         Source="{Binding InputImageSource}"
                         Stretch="{Binding ImageStretch}"
                         IsVisible="{Binding InputImageVisible}" />
                </Border>
                <Border Grid.Column="0"
                        Name="SliderCompareHandle"
                        Width="16"
                        HorizontalAlignment="Right"
                        Margin="0,0,-8,0"
                        Background="Transparent"
                        Cursor="SizeWestEast"
                        PointerPressed="SliderCompareHandle_PointerPressed"
                        PointerMoved="SliderCompareHandle_PointerMoved"
                        PointerReleased="SliderCompareHandle_PointerReleased">
                  <Border Width="2" Background="{DynamicResource PrimaryBrush}" HorizontalAlignment="Center" />
                </Border>
                <TextBlock Text="{Binding OutputPlaceholderText}" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="18" IsVisible="{Binding OutputPlaceholderVisible}" />
              </Grid>
            </Grid>
          </Border>
        </Grid>
      </Grid>

      <Border Grid.Column="2" Background="{DynamicResource PanelSurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="1,0,0,0">
        <TabControl SelectedIndex="{Binding SelectedToolTabIndex, Mode=TwoWay}" Margin="12">
          <TabItem Header="算子">
            <Grid RowDefinitions="Auto,*" RowSpacing="10">
              <TextBox Text="{Binding OperatorSearchText, Mode=TwoWay}" PlaceholderText="搜索算子" />
              <ListBox Grid.Row="1"
                       ItemsSource="{Binding FilteredOperators}"
                       SelectedItem="{Binding SelectedOperator, Mode=TwoWay}">
                <ListBox.ItemTemplate>
                  <DataTemplate x:DataType="models:OperatorViewModel">
                    <Border Margin="0,0,0,8" Padding="10" CornerRadius="8" Background="{DynamicResource CardSurfaceBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1">
                      <Grid ColumnDefinitions="3,*,Auto">
                        <Border Width="3" CornerRadius="2" Background="{DynamicResource PrimaryBrush}" />
                        <StackPanel Grid.Column="1" Margin="9,0" Spacing="3">
                          <TextBlock Text="{Binding CategoryDisplay}" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" />
                          <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{DynamicResource TextBodyBrush}" />
                          <TextBlock Text="{Binding Description}" FontSize="12" TextWrapping="Wrap" Foreground="{DynamicResource TextSecondaryBrush}" />
                        </StackPanel>
                        <Button Grid.Column="2" Classes="toolbarIcon" ToolTip.Tip="添加步骤" Command="{Binding AddCommand}" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                          <TextBlock Text="+" FontSize="18" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Button>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListBox.ItemTemplate>
              </ListBox>
            </Grid>
          </TabItem>

          <TabItem Header="属性">
            <Grid RowDefinitions="Auto,*,Auto" RowSpacing="12">
              <StackPanel Spacing="3">
                <TextBlock Text="{Binding InspectorSubtitleText}" Classes="h1" />
                <TextBlock Text="{Binding OperatorDescriptionText}" Classes="caption" TextWrapping="Wrap" />
              </StackPanel>

              <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <StackPanel Spacing="8">
                  <Border Background="{DynamicResource CardSurfaceBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" IsVisible="{Binding InspectorParametersVisible}">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="10">
                      <TextBlock Text="{Binding ParamANameText}" Classes="sectionTitle" VerticalAlignment="Center" />
                      <TextBox Grid.Column="1" Classes="paramInput" Text="{Binding ParamAText, Mode=TwoWay}" />
                      <Slider Grid.Row="1" Grid.ColumnSpan="2" Classes="paramSlider" Minimum="{Binding ParamAMinimum}" Maximum="{Binding ParamAMaximum}" Value="{Binding ParamAValue, Mode=TwoWay}" TickFrequency="1" />
                    </Grid>
                  </Border>

                  <Border Background="{DynamicResource CardSurfaceBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="10" IsVisible="{Binding InspectorParametersVisible}">
                    <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="8" ColumnSpacing="10">
                      <TextBlock Text="{Binding ParamBNameText}" Classes="sectionTitle" VerticalAlignment="Center" />
                      <TextBox Grid.Column="1" Classes="paramInput" Text="{Binding ParamBText, Mode=TwoWay}" IsVisible="{Binding IsStandardParamBVisible}" />
                      <Slider Grid.Row="1" Grid.ColumnSpan="2" Classes="paramSlider" Minimum="{Binding ParamBMinimum}" Maximum="{Binding ParamBMaximum}" Value="{Binding ParamBValue, Mode=TwoWay}" TickFrequency="1" IsVisible="{Binding IsStandardParamBVisible}" />
                      <Border Grid.Row="1" Grid.ColumnSpan="2" Background="{DynamicResource ControlSurfaceBrush}" BorderBrush="{DynamicResource ControlBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="2" IsVisible="{Binding IsParamBOptionsVisible}">
                        <ItemsControl ItemsSource="{Binding ParamBOptions}">
                          <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                              <StackPanel Orientation="Horizontal" Spacing="2" />
                            </ItemsPanelTemplate>
                          </ItemsControl.ItemsPanel>
                          <ItemsControl.ItemTemplate>
                            <DataTemplate>
                              <Button Classes="modeSegment" Classes.active="{Binding IsSelected}" MinWidth="74" Content="{Binding Label}" Command="{Binding SelectCommand}" />
                            </DataTemplate>
                          </ItemsControl.ItemTemplate>
                        </ItemsControl>
                      </Border>
                    </Grid>
                  </Border>

                  <Border Background="{DynamicResource CardSurfaceBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12" IsVisible="{Binding InspectorOutputVisible}">
                    <StackPanel Spacing="10">
                      <TextBlock Text="步骤设置" Classes="sectionTitle" />
                      <CheckBox Content="启用" IsChecked="{Binding IsStepEnabled, Mode=TwoWay}" />
                      <CheckBox Content="限制像素范围" IsChecked="{Binding IsClampEnabled, Mode=TwoWay}" />
                    </StackPanel>
                  </Border>

                  <Border Background="{DynamicResource CardSurfaceBrush}" BorderBrush="{DynamicResource CardBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="8">
                      <TextBlock Text="详情" Classes="sectionTitle" />
                      <TextBlock Text="{Binding NodeDetailsText}" Foreground="{DynamicResource TextMutedBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                  </Border>
                </StackPanel>
              </ScrollViewer>

              <Grid Grid.Row="2" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8">
                <Button Grid.Column="1" Content="预览" MinWidth="84" Command="{Binding PreviewCommand}" />
                <Button Grid.Column="2" Classes="primary" Content="添加步骤" MinWidth="92" Command="{Binding AddStepCommand}" />
              </Grid>
            </Grid>
          </TabItem>
        </TabControl>
      </Border>
    </Grid>

    <Border Grid.Row="2" Height="{Binding PipelinePaneHeight}" Background="{DynamicResource PanelSurfaceBrush}" BorderBrush="{DynamicResource DividerBrush}" BorderThickness="0,1,0,1">
      <Grid RowDefinitions="Auto,*" Margin="16,10">
        <Grid ColumnDefinitions="Auto,*,Auto">
          <TextBlock Text="处理流程" Classes="h1" />
          <TextBlock Grid.Column="1" Text="{Binding PipelineSummaryText}" Margin="12,0" VerticalAlignment="Center" Classes="caption" />
          <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6">
            <Button Classes="toolbarIcon" ToolTip.Tip="展开/收起处理流程" Command="{Binding TogglePipelineDensityCommand}">
              <Viewbox Width="18" Height="18">
                <Canvas Width="24" Height="24">
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M6,5 L18,5" />
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M6,19 L18,19" />
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M8,10 L12,6 L16,10" />
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M8,14 L12,18 L16,14" />
                </Canvas>
              </Viewbox>
            </Button>
            <Button Classes="toolbarIcon" ToolTip.Tip="将选中步骤前移" Command="{Binding MoveUpCommand}">
              <Viewbox Width="18" Height="18">
                <Canvas Width="24" Height="24">
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M15,6 L9,12 L15,18" />
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M10,12 L21,12" />
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M4,5 L4,19" />
                </Canvas>
              </Viewbox>
            </Button>
            <Button Classes="toolbarIcon" ToolTip.Tip="将选中步骤后移" Command="{Binding MoveDownCommand}">
              <Viewbox Width="18" Height="18">
                <Canvas Width="24" Height="24">
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M9,6 L15,12 L9,18" />
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M3,12 L14,12" />
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M20,5 L20,19" />
                </Canvas>
              </Viewbox>
            </Button>
            <Button Classes="toolbarIcon" ToolTip.Tip="删除选中步骤" Command="{Binding DeleteStepCommand}">
              <Viewbox Width="18" Height="18">
                <Canvas Width="24" Height="24">
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M4,7 L20,7" />
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M10,11 L10,17" />
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M14,11 L14,17" />
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M6,7 L7,21 L17,21 L18,7" />
                  <Path Stroke="{DynamicResource TextBodyBrush}" StrokeThickness="2" StrokeLineCap="Round" Data="M9,7 L9,4 L15,4 L15,7" />
                </Canvas>
              </Viewbox>
            </Button>
          </StackPanel>
        </Grid>

        <ListBox Grid.Row="1"
                 Classes="flow"
                 Margin="0,10,0,0"
                 ItemsSource="{Binding PipelineNodes}"
                 SelectedItem="{Binding SelectedPipelineNode, Mode=TwoWay}"
                 ScrollViewer.HorizontalScrollBarVisibility="Auto"
                 ScrollViewer.VerticalScrollBarVisibility="Disabled">
          <ListBox.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ListBox.ItemsPanel>
          <ListBox.ItemTemplate>
            <DataTemplate x:DataType="models:PipelineNodeViewModel">
              <Grid ColumnDefinitions="184,34">
                <Border Margin="20 0 0 0" Padding="{Binding CardPadding}" Width="184" Height="{Binding CardHeight}" CornerRadius="8" Background="{DynamicResource CardSurfaceBrush}" BorderBrush="{Binding CardBorderBrush}" BorderThickness="{Binding CardBorderThickness}">
                  <Grid RowDefinitions="Auto,*,Auto" ColumnDefinitions="4,*">
                    <Border Grid.RowSpan="3" Width="4" CornerRadius="2" Background="{Binding AccentBrush}" />
                    <Grid Grid.Column="1" ColumnDefinitions="*,Auto" Margin="10,0,0,0">
                      <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" Foreground="{DynamicResource TextBodyBrush}" />
                      <Button Grid.Column="1" Classes="switchButton" ToolTip.Tip="{Binding ToggleText}" IsVisible="{Binding IsToggleVisible}" Command="{Binding ToggleCommand}">
                        <Grid Width="36" Height="20" ColumnDefinitions="*,*">
                          <Border Grid.ColumnSpan="2" CornerRadius="10" Background="{Binding StatusSurfaceBrush}" BorderBrush="{Binding StatusBorderBrush}" BorderThickness="1" />
                          <Border Grid.Column="{Binding SwitchKnobColumn}" Width="16" Height="16" Margin="2" CornerRadius="8" Background="{Binding StatusTextBrush}" />
                        </Grid>
                      </Button>
                    </Grid>
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="10,8,0,0" Text="{Binding Subtitle}" FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}" TextWrapping="Wrap" MaxHeight="36" IsVisible="{Binding IsSubtitleVisible}" />
                    <Border Grid.Row="2" Grid.Column="1" Margin="10,0,0,0" HorizontalAlignment="Left" Background="{Binding StatusSurfaceBrush}" BorderBrush="{Binding StatusBorderBrush}" BorderThickness="1" CornerRadius="10" Padding="7,2">
                      <TextBlock Text="{Binding StatusText}" Foreground="{Binding StatusTextBrush}" FontSize="11" />
                    </Border>
                  </Grid>
                </Border>
                <TextBlock Grid.Column="1" Text="-&gt;" IsVisible="{Binding HasNext}" Foreground="{DynamicResource TextMutedBrush}" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" />
              </Grid>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </Grid>
    </Border>

    <Border Grid.Row="3" Background="{DynamicResource ChromeSurfaceBrush}">
      <Grid ColumnDefinitions="*,Auto" Margin="12,0">
        <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12" />
        <TextBlock Grid.Column="1" Text="OpenCvSharp 图像处理工作台" VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}" FontSize="12" />
      </Grid>
    </Border>
  </Grid>
</Window>
