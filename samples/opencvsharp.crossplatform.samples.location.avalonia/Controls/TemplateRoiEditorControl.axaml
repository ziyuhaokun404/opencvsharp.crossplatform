<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="OpenCvSharp.CrossPlatform.Samples.Location.Avalonia.Controls.TemplateRoiEditorControl"
             Background="Transparent"
             IsVisible="False">
  <Canvas x:Name="Adorner"
          Width="160"
          Height="100"
          RenderTransformOrigin="0.5,0.5">
    <Canvas.RenderTransform>
      <RotateTransform Angle="0" />
    </Canvas.RenderTransform>
    <Border x:Name="Overlay"
            Width="160"
            Height="100"
            BorderBrush="{DynamicResource PrimaryBrush}"
            Background="#332563EB"
            BorderThickness="2"
            Cursor="SizeAll" />
    <Rectangle x:Name="ResizeHandle"
               Width="12"
               Height="12"
               Canvas.Left="154"
               Canvas.Top="94"
               Fill="{DynamicResource PrimaryBrush}"
               Stroke="{DynamicResource PrimaryTextBrush}"
               StrokeThickness="2"
               Cursor="BottomRightCorner" />
    <Ellipse x:Name="RotateHandle"
             Width="12"
             Height="12"
             Canvas.Left="74"
             Canvas.Top="-22"
             Fill="{DynamicResource PrimaryBrush}"
             Stroke="{DynamicResource PrimaryTextBrush}"
             StrokeThickness="2"
             Cursor="Hand" />
  </Canvas>
</UserControl>
